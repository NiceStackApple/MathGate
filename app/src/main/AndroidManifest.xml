<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions required by Math Gate -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:name="com.example.MathGateApplication">

        <!-- Mandatory Developer Property for specialUse Foreground Service on Android 14+ -->
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="Parental Control Screen Time Monitor" />

        <!-- Main settings/config container Activity (No launcher filter directly) -->
        <activity
            android:name="com.example.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication" />

        <!-- Fullscreen Lock screen overlay Activity -->
        <activity
            android:name="com.example.GateActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true" />

        <!-- Activity Aliases for Dynamic App disguising name & icon -->
        <activity-alias
            android:name=".MainActivityDefault"
            android:targetActivity="com.example.MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/ic_launcher_default"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityCalculator"
            android:targetActivity="com.example.MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_calculator"
            android:label="Kalkulator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityWeather"
            android:targetActivity="com.example.MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_weather"
            android:label="Cuaca">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityNotes"
            android:targetActivity="com.example.MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_notes"
            android:label="Notes">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Services -->
        <service
            android:name="com.example.ScreenTimeService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <service
            android:name="com.example.MathGateAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Receivers -->
        <receiver
            android:name="com.example.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
